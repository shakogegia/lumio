{
  "name": "@lumio/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ingest": "dotenv -e ../../.env -- tsx src/main.ts",
    "backfill:thumbhash": "dotenv -e ../../.env -- tsx src/backfill-thumbhash.ts",
    "watch": "dotenv -e ../../.env -- tsx src/watch-main.ts",
    "bench": "dotenv -e ../../.env -- tsx src/bench.ts",
    "seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "test": "TZ=UTC vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lumio/db": "workspace:*",
    "@lumio/ingest": "workspace:*",
    "@lumio/jobs": "workspace:*",
    "@lumio/shared": "workspace:*",
    "chokidar": "^5.0.0",
    "sharp": "^0.33"
  },
  "devDependencies": {
    "@types/node": "^22",
    "dotenv-cli": "^8",
    "tsx": "^4",
    "vitest": "^2"
  }
}

DATABASE_URL="postgresql://lumio:lumio@localhost:5433/lumio?schema=public"
DB_PORT=5433
# Source-of-truth originals + regenerable cache + recoverable trash. Relative
# paths resolve from the repo root. Under Conductor, scripts/conductor/setup.sh
# rewrites these to an absolute shared path ($CONDUCTOR_ROOT_PATH/data/{photos,
# cache,trash}) so every workspace shares one library + cache + trash (like the
# shared Postgres). TRASH_DIR holds deleted originals + their renditions and must
# stay OUTSIDE PHOTOS_DIR so the watcher never re-imports trashed files.
PHOTOS_DIR="./photos"
CACHE_DIR="./cache"
TRASH_DIR="./trash"
# Max upload size accepted by the web app. Always include a unit (b/kb/mb/gb) —
# a bare number is bytes (so "300" = 300 B). Defaults to 200mb.
# MAX_UPLOAD_SIZE="200mb"
# Auth — generate a real secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
# Public origin the app is served from (Cloudflare tunnel hostname in prod)
BETTER_AUTH_URL="http://localhost:3000"
# Optional: extra comma-separated origins to trust for CSRF beyond BETTER_AUTH_URL.
# List every host you reach the app from (LAN IP, Tailscale host, …) or login is
# rejected with INVALID_ORIGIN. (Conductor's run.sh sets this automatically to the
# localhost:<port> origin when the workspace runs behind the portless subdomain.)
# BETTER_AUTH_TRUSTED_ORIGINS="http://192.168.1.50:3000,https://box.tailnet.ts.net"
# Set false to allow logins over plain HTTP (e.g. http://<lan-ip>:3000). Unset =
# Secure in production. ⚠️ Disabling drops the cookie Secure flag on ALL origins —
# only for trusted LAN/Tailscale-only deployments, never a public HTTPS domain.
# USE_SECURE_COOKIES=true
